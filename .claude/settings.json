{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Artifact",
      "Bash(gh:*)",
      "Bash(jq:*)",
      "Bash(git:*)",
      "Bash(date:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cargo test:*)",
      "Bash(cargo build:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh issue close:*)",
      "Bash(gh repo delete:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ]
  }
}
